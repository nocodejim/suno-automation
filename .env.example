# Suno Automation Configuration

# Browser Settings
HEADLESS=true
TIMEOUT=30000
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# Timing Settings (in milliseconds)
DELAY_BETWEEN_SONGS=240000  # 4 minutes
FORM_FILL_DELAY=1000       # 1 second between form fields
SUBMISSION_TIMEOUT=10000    # 10 seconds for form submission

# File Paths
INPUT_CSV=input/songs/my-songs.csv
OUTPUT_DIR=output/completed
LOG_LEVEL=info

# Session Management
SESSION_FILE=session.json
RETRY_ATTEMPTS=3
